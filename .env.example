# ============================================================
# NL2BI Agent — 环境变量配置
# 使用方法：cp .env.example .env  然后编辑 .env
# ============================================================

# ── 语言模型 ──

# DeepSeek API（用于 SQL 生成 + 结果解读，必填）
DEEPSEEK_API_KEY=sk-your-key-here
DEEPSEEK_MODEL=deepseek-chat
DEEPSEEK_BASE_URL=https://api.deepseek.com

# Ollama 本地模型（用于意图分类 + SQL 语义验证）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b

# ── 数据库 ──

PG_HOST=localhost
PG_PORT=5432
PG_DATABASE=bi_demo
PG_USER=bi_agent
PG_PASSWORD=changeme

# ── ChromaDB 向量库 ──

CHROMA_PERSIST_DIR=./chroma_data

# ── 安全策略 ──

MAX_QUERY_TIMEOUT_S=30
MAX_RETURN_ROWS=10000
SQL_READ_ONLY=true

# ── 日志 ──

LOG_LEVEL=INFO
LOG_FORMAT=json
