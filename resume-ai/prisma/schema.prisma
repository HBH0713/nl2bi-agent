generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(uuid())
  email     String   @unique
  createdAt DateTime @default(now())
  analyses  Analysis[]
}

model Analysis {
  id        String   @id @default(uuid())
  userId    String
  fileName  String
  score     Int
  strengths String[]
  weaknesses String[]
  keywords  String[]
  suggestions       Json
  interviewQuestions Json
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id])
}
